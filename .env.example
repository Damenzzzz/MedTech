# ==============================================================================
# KazMedSim (MedTech) Environment Configuration
# Copy this file to `.env.local` for local development.
# DO NOT place real credentials or patient data in this file.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Text LLM Provider Architecture
# Controls patient simulation, AI assistant, RAG fallback, rationale, and protocol generation.
# Allowed values: 'alem' (Production) | 'mock' (CI/Testing)
# OpenAI and Gemini are STRICTLY PROHIBITED for text generation.
# ------------------------------------------------------------------------------
LLM_PROVIDER=alem

# AlemLLM API Configuration
ALEM_BASE_URL=https://llm.alem.ai/v1
ALEM_API_KEY=your_alem_api_key_here
ALEM_CHAT_MODEL=alemllm

# ------------------------------------------------------------------------------
# 2. Speech-to-Text (STT) Provider Architecture
# Controls audio transcription for medical encounter recording.
# Allowed values: 'openai' (Production) | 'mock' (CI/Testing)
# OPENAI_API_KEY is used ONLY for `POST /v1/audio/transcriptions`.
# OPENAI_API_KEY is NEVER read by text LLM providers or RAG fallback.
# ------------------------------------------------------------------------------
STT_PROVIDER=openai

# OpenAI Audio Transcription API Configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_STT_MODEL=gpt-4o-transcribe-diarize
OPENAI_STT_DIARIZATION=true
OPENAI_STT_LANGUAGE=ru

# ------------------------------------------------------------------------------
# 3. RAG Service URL (Optional)
# Microservice URL for Python FastAPI RAG retrieval backend.
# If unconfigured or unavailable, Next.js API fallback uses AlemLLM.
#
# Two servers can live at rag_service/, pick the port that matches which one
# you actually run (see rag_service/README.md):
#   - askhat_rag.server:app (askhat_rag/, ./scripts/run_askhat_rag.sh) -> port 8080
#     BM25+FAISS retrieval, reranking, LLM generation. Implements
#     /api/diagnose-jobs, /api/diagnose-jobs/{job_id}, /api/refine, /api/retrieve
#     -- everything src/app/api/clinical/** actually calls.
#   - app.api.server:app (app/api/, offline fallback) -> port 8000
#     Only /diagnose, /api/analyze, /api/health. No job/refine endpoints.
# ------------------------------------------------------------------------------
RAG_SERVICE_URL=http://127.0.0.1:8080

# ------------------------------------------------------------------------------
# 4. Case Repository Provider
# Allowed values: 'seed'
# ------------------------------------------------------------------------------
CASE_REPOSITORY=seed

# ------------------------------------------------------------------------------
# 5. Supabase Configuration (Optional)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
