# Main LLM switch.
# OpenAI GPT-5.5 is the default clinical reasoning/generation model.
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_me
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=low
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3
GENERATION_MAX_TOKENS=8000
QUERY_ANALYSIS_MAX_TOKENS=1800
TREE_SEARCH_MAX_TOKENS=600

# Optional reranker. Leave empty to disable.
RERANK_BASE_URL=https://llm.alem.ai/v1/rerank
RERANK_API_KEY=replace_me
RERANK_MODEL=reranker
RERANK_TOP_N=8
RERANK_RETRIES=1
RERANK_TIMEOUT_SECONDS=15
RERANK_DOC_MAX_CHARS=1000
HYBRID_TOP_K=16
REFINE_CANDIDATE_POOL_SIZE=16

# Optional second-opinion ensemble.
# Keep disabled when LLM_MODEL is already a GPT-5 family model.
ENSEMBLE_GPT5_ENABLED=0
GPT5_BASE_URL=https://api.openai.com/v1
GPT5_MODEL=gpt-5.5
GPT5_API_KEY=replace_me
GPT5_GENERATION_MAX_TOKENS=8000
GPT5_REASONING_EFFORT=low
ENSEMBLE_JUDGE_MODEL=
ENSEMBLE_JUDGE_MAX_TOKENS=2200
ICD_LOOKUP_TOP_K=16

# Qazcode GPT-OSS compatibility aliases.
# You can use these instead of LLM_* when LLM_PROVIDER=oss.
# LLM_PROVIDER=oss
# GPT_OSS_BASE_URL=https://hub.qazcode.ai/v1
# GPT_OSS_API_KEY=replace_me
# LLM_MODEL=oss-120b

# Embeddings. Keep this aligned with the already-built FAISS index.
EMBED_PROVIDER=custom
EMBED_BASE_URL=https://llm.alem.ai/v1
EMBED_API_KEY=replace_me
EMBED_MODEL=text-1024
EMBED_BATCH_SIZE=256
EMBED_CONCURRENCY=4
USE_MYSTEM=0
KMP_DUPLICATE_LIB_OK=TRUE
EMBED_MAX_RETRIES=7
EMBED_TIMEOUT_SECONDS=90
EMBED_ONLINE_RETRIES=4
EMBED_TEXT_MAX_CHARS=300

# If you want fully local embeddings later:
# EMBED_PROVIDER=local
# EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# Optional: point the Askhat RAG to a different corpus/test set.
CORPUS_PATH=data/corpus/merged_protocols_structured_dedup.jsonl
TEST_SET_PATH=data/test_set/
FEW_SHOT_COUNT=0
STRICT_CONTEXT_ICD=1
ENABLE_TREE_SEARCH=0
